# Runtime
NODE_ENV=development
PORT=6969

# App URLs
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:6969
BASE_URL=http://localhost:6969
BACKEND_BASE_URL=http://localhost:6969
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
COOKIE_DOMAIN=

# Database
MONGO_URI=mongodb://localhost:27017/toy_store

# Auth / sessions
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30m
SESSION_SECRET=replace-with-a-long-random-session-secret
VERIFY_TTL_MINUTES=1440
LOGIN_MAX_FAILS=5
LOGIN_OTP_TTL_MINUTES=10
RESET_TTL_MINUTES=15
CHANGE_EMAIL_OTP_TTL_MINUTES=10
VERIFY_NEW_EMAIL_TOKEN_TTL_MINUTES=15
CHANGE_EMAIL_CONFIRM_URL=http://localhost:5173/profile

# Guest order lookup / internal AI lookup
AI_INTERNAL_SERVICE_KEY=replace-with-shared-internal-service-key
GUEST_ORDER_ACCESS_TOKEN_TTL_DAYS=30
ORDER_LOOKUP_OTP_TTL_MINUTES=10
ORDER_LOOKUP_JWT_SECRET=replace-with-a-long-random-order-lookup-secret
ORDER_LOOKUP_JWT_TTL=15m

# Email / SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MilkyBloom <no-reply@example.com>

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:6969/api/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:6969/api/auth/facebook/callback

# Maps / weather / moderation
VIETMAP_ENABLED=false
VIETMAP_API_KEY=
OPENWEATHER_API_KEY=
WEATHER_ENABLED=false
GEMINI_API_KEY=
GEMINI_ENABLED=false

# Media / defaults
S3_ENABLED=false
AWS_BUCKET_NAME=
AWS_BUCKET_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DEFAULT_AVATAR_URL=

# Payments: MoMo sandbox
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:6969/api/payments/momo/return
MOMO_IPN_URL=http://localhost:6969/api/payments/momo/ipn

# Payments: ZaloPay sandbox
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sandbox.zalopay.com.vn/v001/tpe/createorder
ZALOPAY_QUERY_ENDPOINT=https://sandbox.zalopay.com.vn/v001/tpe/getstatusbyapptransid
ZALOPAY_REDIRECT_URL=http://localhost:6969/api/payments/success
ZALOPAY_CALLBACK_URL=http://localhost:6969/api/payments/zalopay/callback

# Bank transaction sync
BANK_API_KEY=
BANK_HISTORY_URL=

# Chat provider
CHAT_PROVIDER=agentic
CHAT_SYSTEM_PROMPT=You are MilkyBloom customer support. Be warm, concise, and practical.
CHAT_MAX_OUTPUT_TOKENS=300
CHAT_TEMPERATURE=0.3

# Optional remote LLM fallback for legacy chat diagnostics
CHAT_REMOTE_MODE=openai
CHAT_REMOTE_BASE_URL=https://api.featherless.ai/v1
CHAT_REMOTE_MODEL=Qwen/Qwen2.5-7B-Instruct
CHAT_REMOTE_API_KEY=

# EmpathAI / agentic service
AGENTIC_AI_TIMEOUT_MS=120000
AGENTIC_AI_WS_URL=ws://127.0.0.1:8788
