NODE_ENV=development
PORT=6969

# Canonical app URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:6969
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
COOKIE_DOMAIN=

# Core auth
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=30m
SESSION_SECRET=
AI_INTERNAL_SERVICE_KEY=
GUEST_ORDER_ACCESS_TOKEN_TTL_DAYS=30
ORDER_LOOKUP_OTP_TTL_MINUTES=10
ORDER_LOOKUP_JWT_SECRET=
ORDER_LOOKUP_JWT_TTL=15m

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:6969/api/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:6969/api/auth/facebook/callback

# Payments
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_REDIRECT_URL=http://localhost:5173/payment
MOMO_IPN_URL=http://localhost:6969/api/payments/momo/ipn

ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sandbox.zalopay.com.vn/v001/tpe/createorder
ZALOPAY_CALLBACK_URL=http://localhost:6969/api/payments/zalopay/callback
ZALOPAY_REDIRECT_URL=http://localhost:5173/payment

# Maps / weather / AI
VIETMAP_API_KEY=
OPENWEATHER_API_KEY=
GEMINI_API_KEY=

# Chat switch
# agentic -> use the full EmpathAI Python service in agentic-ai/
# auto    -> keep for legacy snapshots; streaming path still uses agentic
CHAT_PROVIDER=agentic
CHAT_SYSTEM_PROMPT=You are MilkyBloom customer support. Be warm, concise, and practical.
CHAT_MAX_OUTPUT_TOKENS=300
CHAT_TEMPERATURE=0.3

# Remote deploy LLM
CHAT_REMOTE_MODE=openai
CHAT_REMOTE_BASE_URL=https://api.featherless.ai/v1
CHAT_REMOTE_MODEL=Qwen/Qwen2.5-7B-Instruct
CHAT_REMOTE_API_KEY=

# EmpathAI / agentic core service
# AGENTIC_AI_BASE_URL is internal-only and not used by the public streaming path
AGENTIC_AI_TIMEOUT_MS=120000
AGENTIC_AI_WS_URL=ws://127.0.0.1:8788

# Optional provider flags
SMTP_ENABLED=true
GEMINI_ENABLED=true
WEATHER_ENABLED=true
VIETMAP_ENABLED=true

# Optional business URLs / bank config
BANK_API_KEY=
BANK_HISTORY_URL=
CHANGE_EMAIL_CONFIRM_URL=
