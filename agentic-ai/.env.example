# Runtime
# ws_server.py uses PORT first, then AGENTIC_WS_PORT.
PORT=8788
AGENTIC_WS_PORT=8788
# Warm up embedding/reranker models and graph at ws_server.py startup.
AGENTIC_WARMUP=true

# Real shop backend API used by agentic tools.
SHOP_API_BASE_URL=http://127.0.0.1:6969/api
BACKEND_URL=http://127.0.0.1:6969/api
BACKEND_BASE_URL=http://127.0.0.1:6969/api
AI_INTERNAL_SERVICE_KEY=replace-with-same-value-as-backend

# LLM provider
EMPATHY_MODE=groq

# Groq OpenAI-compatible backend
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.1-70b-versatile
GROQ_HTTP_REFERER=
GROQ_X_TITLE=EmpathAI

# Featherless OpenAI-compatible fallback / alternate mode
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_SMART=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_HTTP_REFERER=
FEATHERLESS_X_TITLE=EmpathAI

# Retrieval
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=empathAI_policies
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RRF_DENSE_WEIGHT=0.6
RRF_SPARSE_WEIGHT=0.4
RRF_K=60

# Optional Redis cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_CACHE_TTL=604800

# Optional Langfuse tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com

# Kafka is optional for legacy worker flow. ws_server.py does not require it.
KAFKA_BROKERS=localhost:9092
