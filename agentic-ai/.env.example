# Groq OpenAI-compatible LLM backend
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.1-70b-versatile
GROQ_HTTP_REFERER=
GROQ_X_TITLE=EmpathAI

# Featherless OpenAI-compatible LLM backend
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MODEL_SMART=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_HTTP_REFERER=
FEATHERLESS_X_TITLE=EmpathAI

# Keep the agentic pipeline, but swap the LLM backend
# Default production path: Groq first, Featherless fallback
EMPATHY_MODE=groq
